{
  "info": {
    "title": "Hello World Application API",
    "version": "1.0.0",
    "description": "Complete API specification for Hello World application with mobile support"
  },
  "paths": {
    "/mobile/sync": {
      "post": {
        "tags": [
          "Mobile"
        ],
        "summary": "Sync offline data",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SyncResponse"
                }
              }
            },
            "description": "Data synchronized"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OfflineSync"
              }
            }
          },
          "required": true
        }
      }
    },
    "/mobile/devices": {
      "get": {
        "tags": [
          "Mobile"
        ],
        "summary": "Get registered mobile devices",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MobileDevice"
                  }
                }
              }
            },
            "description": "List of registered devices"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/mobile/register": {
      "post": {
        "tags": [
          "Mobile"
        ],
        "summary": "Register mobile device",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MobileDeviceResponse"
                }
              }
            },
            "description": "Device registered successfully"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MobileDeviceRegistration"
              }
            }
          },
          "required": true
        }
      }
    },
    "/mobile/push-token": {
      "put": {
        "tags": [
          "Mobile"
        ],
        "summary": "Update push notification token",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiResponse"
                }
              }
            },
            "description": "Push token updated"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PushTokenUpdate"
              }
            }
          },
          "required": true
        }
      }
    },
    "/auth/biometric/verify": {
      "post": {
        "tags": [
          "Authentication",
          "Mobile"
        ],
        "summary": "Verify biometric authentication",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthToken"
                }
              }
            },
            "description": "Biometric authentication successful"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BiometricVerification"
              }
            }
          },
          "required": true
        }
      }
    },
    "/auth/biometric/register": {
      "post": {
        "tags": [
          "Authentication",
          "Mobile"
        ],
        "summary": "Register biometric authentication",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BiometricResponse"
                }
              }
            },
            "description": "Biometric authentication registered"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BiometricRegistration"
              }
            }
          },
          "required": true
        }
      }
    },
    "/mobile/devices/{deviceId}": {
      "delete": {
        "tags": [
          "Mobile"
        ],
        "summary": "Unregister mobile device",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "204": {
            "description": "Device unregistered successfully"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "deviceId",
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true
          }
        ]
      }
    }
  },
  "openapi": "3.0.0",
  "servers": [
    {
      "url": "/api/v1"
    }
  ],
  "components": {
    "schemas": {
      "AuthToken": {
        "type": "object",
        "properties": {
          "expiresIn": {
            "type": "integer"
          },
          "tokenType": {
            "type": "string",
            "default": "Bearer"
          },
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          }
        }
      },
      "ApiResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "success": {
            "type": "boolean"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "OfflineSync": {
        "type": "object",
        "required": [
          "deviceId",
          "lastSync"
        ],
        "properties": {
          "deviceId": {
            "type": "string",
            "format": "uuid"
          },
          "lastSync": {
            "type": "string",
            "format": "date-time"
          },
          "pendingActions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OfflineAction"
            }
          }
        }
      },
      "MobileDevice": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "deviceId": {
            "type": "string"
          },
          "platform": {
            "enum": [
              "ios",
              "android"
            ],
            "type": "string"
          },
          "timezone": {
            "type": "string"
          },
          "osVersion": {
            "type": "string"
          },
          "pushToken": {
            "type": "string"
          },
          "appVersion": {
            "type": "string"
          },
          "deviceName": {
            "type": "string"
          },
          "lastActive": {
            "type": "string",
            "format": "date-time"
          },
          "registered": {
            "type": "string",
            "format": "date-time"
          },
          "biometricEnabled": {
            "type": "boolean"
          }
        }
      },
      "SyncConflict": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string"
          },
          "actionId": {
            "type": "string"
          },
          "resolution": {
            "enum": [
              "server_wins",
              "client_wins",
              "manual_required"
            ],
            "type": "string"
          }
        }
      },
      "SyncResponse": {
        "type": "object",
        "properties": {
          "lastSync": {
            "type": "string",
            "format": "date-time"
          },
          "conflicts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SyncConflict"
            }
          },
          "syncedActions": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "OfflineAction": {
        "type": "object",
        "required": [
          "type",
          "timestamp"
        ],
        "properties": {
          "data": {
            "type": "object"
          },
          "type": {
            "enum": [
              "profile_update",
              "notification_read",
              "preference_change"
            ],
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "PushTokenUpdate": {
        "type": "object",
        "required": [
          "deviceId",
          "pushToken"
        ],
        "properties": {
          "deviceId": {
            "type": "string",
            "format": "uuid"
          },
          "pushToken": {
            "type": "string",
            "maxLength": 500
          }
        }
      },
      "BiometricResponse": {
        "type": "object",
        "properties": {
          "challenge": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "registered": {
            "type": "boolean"
          }
        }
      },
      "MobileDeviceResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "deviceId": {
            "type": "string",
            "format": "uuid"
          },
          "registered": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "BiometricRegistration": {
        "type": "object",
        "required": [
          "deviceId",
          "biometricType",
          "publicKey"
        ],
        "properties": {
          "deviceId": {
            "type": "string",
            "format": "uuid"
          },
          "publicKey": {
            "type": "string",
            "maxLength": 1000
          },
          "biometricType": {
            "enum": [
              "fingerprint",
              "face_id",
              "touch_id"
            ],
            "type": "string"
          }
        }
      },
      "BiometricVerification": {
        "type": "object",
        "required": [
          "deviceId",
          "signature",
          "challenge"
        ],
        "properties": {
          "deviceId": {
            "type": "string",
            "format": "uuid"
          },
          "challenge": {
            "type": "string",
            "maxLength": 500
          },
          "signature": {
            "type": "string",
            "maxLength": 1000
          }
        }
      },
      "MobileDeviceRegistration": {
        "type": "object",
        "required": [
          "platform",
          "deviceId",
          "deviceName"
        ],
        "properties": {
          "deviceId": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1
          },
          "platform": {
            "enum": [
              "ios",
              "android"
            ],
            "type": "string"
          },
          "timezone": {
            "type": "string",
            "maxLength": 50
          },
          "osVersion": {
            "type": "string",
            "maxLength": 50
          },
          "pushToken": {
            "type": "string",
            "maxLength": 500
          },
          "appVersion": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "deviceName": {
            "type": "string",
            "maxLength": 100,
            "minLength": 1
          }
        }
      }
    },
    "responses": {
      "NotFound": {
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Resource not found"
                }
              }
            }
          }
        },
        "description": "Resource not found"
      },
      "BadRequest": {
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string"
                },
                "details": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "description": "Invalid request"
      },
      "Unauthorized": {
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Authentication required"
                }
              }
            }
          }
        },
        "description": "Authentication required"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}