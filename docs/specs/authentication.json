{
  "roles": [
    "user",
    "admin"
  ],
  "security": {
    "lockout": {
      "maxAttempts": 5,
      "lockoutDuration": "15 minutes"
    },
    "tokenSecurity": {
      "issuer": "ecommerce-app",
      "audience": "ecommerce-users",
      "algorithm": "HS256"
    },
    "passwordRequirements": {
      "minLength": 8,
      "requireNumbers": true,
      "requireLowercase": true,
      "requireUppercase": true,
      "requireSpecialChars": true
    }
  },
  "strategy": "JWT with refresh tokens",
  "permissions": {
    "user": [
      "profile:read",
      "profile:update",
      "orders:read",
      "cart:manage"
    ],
    "admin": [
      "*"
    ]
  },
  "rateLimiting": {
    "login": "10 per 15 minutes per IP",
    "register": "5 per 15 minutes per IP",
    "forgotPassword": "3 per 15 minutes per email",
    "resendVerification": "3 per 5 minutes per email"
  },
  "accessTokenExpiry": "15m",
  "refreshTokenExpiry": "30d",
  "passwordResetExpiry": "1h",
  "rememberMeTokenExpiry": "30d",
  "emailVerificationExpiry": "24h"
}