{
  "roles": [
    "admin",
    "user"
  ],
  "strategy": "JWT with biometric support",
  "permissions": {
    "mobile.register": [
      "user",
      "admin"
    ],
    "biometric.verify": [
      "user",
      "admin"
    ],
    "biometric.register": [
      "user",
      "admin"
    ],
    "mobile.manage_devices": [
      "user",
      "admin"
    ]
  },
  "tokenExpiry": "15m",
  "biometricAuth": {
    "supportedTypes": [
      "fingerprint",
      "face_id",
      "touch_id"
    ],
    "challengeExpiry": "5m",
    "keyRotationInterval": "30d"
  },
  "refreshTokenExpiry": "7d"
}