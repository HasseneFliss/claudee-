{
  "summary": "Comprehensive authentication specification for Next.js e-commerce application with JWT-based auth, Google OAuth, email verification, password reset, session management, and robust security features. Includes 15 API endpoints, 6 database tables, rate limiting, audit logging, and production-ready security measures.",
  "openApiSpec": {
    "info": {
      "title": "E-commerce Authentication API",
      "version": "1.0.0",
      "description": "Complete authentication API for Next.js e-commerce application with JWT, OAuth, and email verification"
    },
    "paths": {
      "/auth/me": {
        "get": {
          "tags": [
            "Authentication",
            "Profile"
          ],
          "summary": "Get current user profile",
          "security": [
            {
              "bearerAuth": []
            }
          ],
          "responses": {
            "200": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/UserProfile"
                  }
                }
              },
              "description": "Current user profile"
            },
            "401": {
              "$ref": "#/components/responses/Unauthorized"
            },
            "500": {
              "$ref": "#/components/responses/ServerError"
            }
          }
        }
      },
      "/auth/login": {
        "post": {
          "tags": [
            "Authentication"
          ],
          "summary": "Login with email and password",
          "responses": {
            "200": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/LoginResponse"
                  }
                }
              },
              "headers": {
                "Set-Cookie": {
                  "schema": {
                    "type": "string"
                  },
                  "description": "Refresh token as httpOnly cookie"
                }
              },
              "description": "Login successful"
            },
            "400": {
              "$ref": "#/components/responses/BadRequest"
            },
            "401": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ErrorResponse"
                  }
                }
              },
              "description": "Invalid credentials or unverified email"
            },
            "423": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ErrorResponse"
                  }
                }
              },
              "description": "Account temporarily locked"
            },
            "429": {
              "$ref": "#/components/responses/RateLimit"
            },
            "500": {
              "$ref": "#/components/responses/ServerError"
            }
          },
          "requestBody": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginRequest"
                }
              }
            },
            "required": true
          }
        }
      },
      "/auth/logout": {
        "post": {
          "tags": [
            "Authentication"
          ],
          "summary": "Logout and invalidate tokens",
          "security": [
            {
              "bearerAuth": []
            }
          ],
          "responses": {
            "200": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/SuccessResponse"
                  }
                }
              },
              "headers": {
                "Set-Cookie": {
                  "schema": {
                    "type": "string"
                  },
                  "description": "Clear refresh token cookie"
                }
              },
              "description": "Logout successful"
            },
            "401": {
              "$ref": "#/components/responses/Unauthorized"
            },
            "500": {
              "$ref": "#/components/responses/ServerError"
            }
          }
        }
      },
      "/auth/refresh": {
        "post": {
          "tags": [
            "Authentication"
          ],
          "summary": "Refresh access token",
          "responses": {
            "200": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/RefreshResponse"
                  }
                }
              },
              "description": "New access token generated"
            },
            "401": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ErrorResponse"
                  }
                }
              },
              "description": "Invalid or expired refresh token"
            },
            "500": {
              "$ref": "#/components/responses/ServerError"
            }
          }
        }
      },
      "/auth/register": {
        "post": {
          "tags": [
            "Authentication"
          ],
          "summary": "Register new user with email and password",
          "responses": {
            "201": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/RegisterResponse"
                  }
                }
              },
              "description": "User registered successfully, verification email sent"
            },
            "400": {
              "$ref": "#/components/responses/BadRequest"
            },
            "409": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ErrorResponse"
                  }
                }
              },
              "description": "Email already exists"
            },
            "429": {
              "$ref": "#/components/responses/RateLimit"
            },
            "500": {
              "$ref": "#/components/responses/ServerError"
            }
          },
          "requestBody": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterRequest"
                }
              }
            },
            "required": true
          }
        }
      },
      "/auth/sessions": {
        "get": {
          "tags": [
            "Authentication",
            "Sessions"
          ],
          "summary": "Get active user sessions",
          "security": [
            {
              "bearerAuth": []
            }
          ],
          "responses": {
            "200": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/SessionsResponse"
                  }
                }
              },
              "description": "List of active sessions"
            },
            "401": {
              "$ref": "#/components/responses/Unauthorized"
            },
            "500": {
              "$ref": "#/components/responses/ServerError"
            }
          }
        }
      },
      "/auth/link-oauth": {
        "post": {
          "tags": [
            "Authentication",
            "OAuth"
          ],
          "summary": "Link OAuth account to existing user",
          "security": [
            {
              "bearerAuth": []
            }
          ],
          "responses": {
            "200": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/SuccessResponse"
                  }
                }
              },
              "description": "OAuth account linked successfully"
            },
            "400": {
              "$ref": "#/components/responses/BadRequest"
            },
            "401": {
              "$ref": "#/components/responses/Unauthorized"
            },
            "409": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ErrorResponse"
                  }
                }
              },
              "description": "OAuth account already linked to another user"
            },
            "500": {
              "$ref": "#/components/responses/ServerError"
            }
          },
          "requestBody": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LinkOAuthRequest"
                }
              }
            },
            "required": true
          }
        }
      },
      "/auth/oauth/google": {
        "get": {
          "tags": [
            "Authentication",
            "OAuth"
          ],
          "summary": "Initiate Google OAuth flow",
          "responses": {
            "302": {
              "headers": {
                "Location": {
                  "schema": {
                    "type": "string"
                  }
                }
              },
              "description": "Redirect to Google OAuth"
            },
            "400": {
              "$ref": "#/components/responses/BadRequest"
            },
            "500": {
              "$ref": "#/components/responses/ServerError"
            }
          },
          "parameters": [
            {
              "in": "query",
              "name": "type",
              "schema": {
                "enum": [
                  "login",
                  "register"
                ],
                "type": "string"
              },
              "required": true
            },
            {
              "in": "query",
              "name": "redirect_uri",
              "schema": {
                "type": "string",
                "format": "uri"
              },
              "required": false
            }
          ]
        }
      },
      "/auth/unlink-oauth": {
        "post": {
          "tags": [
            "Authentication",
            "OAuth"
          ],
          "summary": "Unlink OAuth account",
          "security": [
            {
              "bearerAuth": []
            }
          ],
          "responses": {
            "200": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/SuccessResponse"
                  }
                }
              },
              "description": "OAuth account unlinked successfully"
            },
            "400": {
              "$ref": "#/components/responses/BadRequest"
            },
            "401": {
              "$ref": "#/components/responses/Unauthorized"
            },
            "500": {
              "$ref": "#/components/responses/ServerError"
            }
          },
          "requestBody": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnlinkOAuthRequest"
                }
              }
            },
            "required": true
          }
        }
      },
      "/auth/verify-email": {
        "get": {
          "tags": [
            "Authentication",
            "Email"
          ],
          "summary": "Verify email address",
          "responses": {
            "200": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/SuccessResponse"
                  }
                }
              },
              "description": "Email verified successfully"
            },
            "400": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ErrorResponse"
                  }
                }
              },
              "description": "Invalid or expired token"
            },
            "409": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ErrorResponse"
                  }
                }
              },
              "description": "Email already verified"
            },
            "500": {
              "$ref": "#/components/responses/ServerError"
            }
          },
          "parameters": [
            {
              "in": "query",
              "name": "token",
              "schema": {
                "type": "string"
              },
              "required": true
            }
          ]
        }
      },
      "/auth/reset-password": {
        "post": {
          "tags": [
            "Authentication",
            "Password"
          ],
          "summary": "Reset password with token",
          "responses": {
            "200": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/SuccessResponse"
                  }
                }
              },
              "description": "Password reset successful"
            },
            "400": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ErrorResponse"
                  }
                }
              },
              "description": "Invalid token or password validation failed"
            },
            "500": {
              "$ref": "#/components/responses/ServerError"
            }
          },
          "requestBody": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResetPasswordRequest"
                }
              }
            },
            "required": true
          }
        }
      },
      "/auth/change-password": {
        "post": {
          "tags": [
            "Authentication",
            "Password"
          ],
          "summary": "Change password for authenticated user",
          "security": [
            {
              "bearerAuth": []
            }
          ],
          "responses": {
            "200": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/SuccessResponse"
                  }
                }
              },
              "description": "Password changed successfully"
            },
            "400": {
              "$ref": "#/components/responses/BadRequest"
            },
            "401": {
              "$ref": "#/components/responses/Unauthorized"
            },
            "500": {
              "$ref": "#/components/responses/ServerError"
            }
          },
          "requestBody": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChangePasswordRequest"
                }
              }
            },
            "required": true
          }
        }
      },
      "/auth/forgot-password": {
        "post": {
          "tags": [
            "Authentication",
            "Password"
          ],
          "summary": "Request password reset",
          "responses": {
            "200": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/SuccessResponse"
                  }
                }
              },
              "description": "Password reset email sent if email exists"
            },
            "400": {
              "$ref": "#/components/responses/BadRequest"
            },
            "429": {
              "$ref": "#/components/responses/RateLimit"
            },
            "500": {
              "$ref": "#/components/responses/ServerError"
            }
          },
          "requestBody": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForgotPasswordRequest"
                }
              }
            },
            "required": true
          }
        }
      },
      "/auth/resend-verification": {
        "post": {
          "tags": [
            "Authentication",
            "Email"
          ],
          "summary": "Resend email verification",
          "responses": {
            "200": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/SuccessResponse"
                  }
                }
              },
              "description": "Verification email sent"
            },
            "400": {
              "$ref": "#/components/responses/BadRequest"
            },
            "409": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ErrorResponse"
                  }
                }
              },
              "description": "Email already verified"
            },
            "429": {
              "$ref": "#/components/responses/RateLimit"
            },
            "500": {
              "$ref": "#/components/responses/ServerError"
            }
          },
          "requestBody": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResendVerificationRequest"
                }
              }
            },
            "required": true
          }
        }
      },
      "/auth/sessions/{sessionId}": {
        "delete": {
          "tags": [
            "Authentication",
            "Sessions"
          ],
          "summary": "Revoke specific session",
          "security": [
            {
              "bearerAuth": []
            }
          ],
          "responses": {
            "200": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/SuccessResponse"
                  }
                }
              },
              "description": "Session revoked successfully"
            },
            "401": {
              "$ref": "#/components/responses/Unauthorized"
            },
            "404": {
              "$ref": "#/components/responses/NotFound"
            },
            "500": {
              "$ref": "#/components/responses/ServerError"
            }
          },
          "parameters": [
            {
              "in": "path",
              "name": "sessionId",
              "schema": {
                "type": "string",
                "format": "uuid"
              },
              "required": true
            }
          ]
        }
      },
      "/auth/oauth/google/callback": {
        "get": {
          "tags": [
            "Authentication",
            "OAuth"
          ],
          "summary": "Handle Google OAuth callback",
          "responses": {
            "302": {
              "headers": {
                "Location": {
                  "schema": {
                    "type": "string"
                  }
                },
                "Set-Cookie": {
                  "schema": {
                    "type": "string"
                  }
                }
              },
              "description": "OAuth successful, redirect with tokens"
            },
            "400": {
              "$ref": "#/components/responses/BadRequest"
            },
            "409": {
              "content": {
                "application/json": {
                  "schema": {
                    "$ref": "#/components/schemas/ErrorResponse"
                  }
                }
              },
              "description": "Account exists with different method"
            },
            "500": {
              "$ref": "#/components/responses/ServerError"
            }
          },
          "parameters": [
            {
              "in": "query",
              "name": "code",
              "schema": {
                "type": "string"
              },
              "required": true
            },
            {
              "in": "query",
              "name": "state",
              "schema": {
                "type": "string"
              },
              "required": true
            },
            {
              "in": "query",
              "name": "error",
              "schema": {
                "type": "string"
              },
              "required": false
            }
          ]
        }
      }
    },
    "openapi": "3.0.0",
    "servers": [
      {
        "url": "/api/v1"
      }
    ],
    "components": {
      "schemas": {
        "SessionInfo": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid"
            },
            "current": {
              "type": "boolean"
            },
            "location": {
              "type": "string"
            },
            "createdAt": {
              "type": "string",
              "format": "date-time"
            },
            "ipAddress": {
              "type": "string"
            },
            "deviceInfo": {
              "type": "string"
            },
            "lastUsedAt": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "UserProfile": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid"
            },
            "role": {
              "enum": [
                "user",
                "admin"
              ],
              "type": "string"
            },
            "email": {
              "type": "string",
              "format": "email"
            },
            "lastName": {
              "type": "string"
            },
            "createdAt": {
              "type": "string",
              "format": "date-time"
            },
            "firstName": {
              "type": "string"
            },
            "updatedAt": {
              "type": "string",
              "format": "date-time"
            },
            "lastLoginAt": {
              "type": "string",
              "format": "date-time"
            },
            "authProviders": {
              "type": "array",
              "items": {
                "enum": [
                  "email",
                  "google"
                ],
                "type": "string"
              }
            },
            "emailVerified": {
              "type": "boolean"
            }
          }
        },
        "LoginRequest": {
          "type": "object",
          "required": [
            "email",
            "password"
          ],
          "properties": {
            "email": {
              "type": "string",
              "format": "email"
            },
            "password": {
              "type": "string"
            },
            "rememberMe": {
              "type": "boolean",
              "default": false
            }
          }
        },
        "ErrorResponse": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string"
            },
            "error": {
              "type": "string"
            },
            "details": {
              "type": "object"
            },
            "message": {
              "type": "string"
            },
            "success": {
              "type": "boolean",
              "example": false
            }
          }
        },
        "LoginResponse": {
          "type": "object",
          "properties": {
            "user": {
              "$ref": "#/components/schemas/UserProfile"
            },
            "message": {
              "type": "string",
              "example": "Login successful"
            },
            "success": {
              "type": "boolean",
              "example": true
            },
            "expiresIn": {
              "type": "integer",
              "example": 900
            },
            "tokenType": {
              "type": "string",
              "example": "Bearer"
            },
            "accessToken": {
              "type": "string"
            }
          }
        },
        "RefreshResponse": {
          "type": "object",
          "properties": {
            "expiresIn": {
              "type": "integer",
              "example": 900
            },
            "tokenType": {
              "type": "string",
              "example": "Bearer"
            },
            "accessToken": {
              "type": "string"
            }
          }
        },
        "RegisterRequest": {
          "type": "object",
          "required": [
            "email",
            "password",
            "firstName",
            "lastName"
          ],
          "properties": {
            "email": {
              "type": "string",
              "format": "email",
              "maxLength": 255
            },
            "lastName": {
              "type": "string",
              "maxLength": 100,
              "minLength": 1
            },
            "password": {
              "type": "string",
              "maxLength": 128,
              "minLength": 8
            },
            "firstName": {
              "type": "string",
              "maxLength": 100,
              "minLength": 1
            },
            "acceptTerms": {
              "enum": [
                true
              ],
              "type": "boolean"
            },
            "marketingOptIn": {
              "type": "boolean",
              "default": false
            }
          }
        },
        "SuccessResponse": {
          "type": "object",
          "properties": {
            "message": {
              "type": "string"
            },
            "success": {
              "type": "boolean",
              "example": true
            }
          }
        },
        "ValidationError": {
          "type": "object",
          "properties": {
            "error": {
              "type": "string",
              "example": "Validation failed"
            },
            "errors": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "code": {
                    "type": "string"
                  },
                  "field": {
                    "type": "string"
                  },
                  "message": {
                    "type": "string"
                  }
                }
              }
            },
            "message": {
              "type": "string"
            },
            "success": {
              "type": "boolean",
              "example": false
            }
          }
        },
        "LinkOAuthRequest": {
          "type": "object",
          "required": [
            "provider",
            "code"
          ],
          "properties": {
            "code": {
              "type": "string"
            },
            "state": {
              "type": "string"
            },
            "provider": {
              "enum": [
                "google"
              ],
              "type": "string"
            }
          }
        },
        "RegisterResponse": {
          "type": "object",
          "properties": {
            "userId": {
              "type": "string",
              "format": "uuid"
            },
            "message": {
              "type": "string",
              "example": "Registration successful. Please check your email for verification."
            },
            "success": {
              "type": "boolean",
              "example": true
            },
            "verificationEmailSent": {
              "type": "boolean",
              "example": true
            }
          }
        },
        "SessionsResponse": {
          "type": "object",
          "properties": {
            "sessions": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/SessionInfo"
              }
            }
          }
        },
        "UnlinkOAuthRequest": {
          "type": "object",
          "required": [
            "provider"
          ],
          "properties": {
            "provider": {
              "enum": [
                "google"
              ],
              "type": "string"
            }
          }
        },
        "ResetPasswordRequest": {
          "type": "object",
          "required": [
            "token",
            "password",
            "confirmPassword"
          ],
          "properties": {
            "token": {
              "type": "string"
            },
            "password": {
              "type": "string",
              "maxLength": 128,
              "minLength": 8
            },
            "confirmPassword": {
              "type": "string"
            }
          }
        },
        "ChangePasswordRequest": {
          "type": "object",
          "required": [
            "currentPassword",
            "newPassword",
            "confirmPassword"
          ],
          "properties": {
            "newPassword": {
              "type": "string",
              "maxLength": 128,
              "minLength": 8
            },
            "confirmPassword": {
              "type": "string"
            },
            "currentPassword": {
              "type": "string"
            }
          }
        },
